# Dialectic — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# ALL of these are server-only. They are read exclusively inside Next.js API
# routes (src/app/api/**) and never bundled into client code. Do NOT prefix any
# of them with NEXT_PUBLIC_.

# ── LLM API keys ──────────────────────────────────────────────────────────────
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Anthropic (Claude): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# From a service-account JSON key (Firebase console → Project settings →
# Service accounts → Generate new private key).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the full private key on one line, keeping the literal "\n" escape
# sequences exactly as they appear in the JSON. The app converts them back to
# real newlines at runtime (see lib/firebaseAdmin.ts in CP1). Keep the quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your...key...here...\n-----END PRIVATE KEY-----\n"
