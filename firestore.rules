rules_version = '2';

// Dialectic never reads or writes Firestore from the client. All access is
// server-side via the Firebase Admin SDK, which bypasses these rules entirely.
// Denying everything here ensures that even if a client somehow obtained config,
// it could not touch the database.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
